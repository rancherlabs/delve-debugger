{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>rancher/renovate-config#release"
  ],
  "baseBranchPatterns": [
    "master"
  ],
  "prHourlyLimit": 20,
  "packageRules": [
    {
      "description": "Group all GitHub Actions updates into a single PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "description": "Group SLE base image updates across all Dockerfiles",
      "matchPackageNames": [
        "registry.suse.com/suse/sle15"
      ],
      "groupName": "sle-base-image",
      "automerge": false
    },
    {
      "description": "Group Go version updates across all Dockerfiles",
      "matchDepNames": [
        "golang-sle"
      ],
      "groupName": "go-version",
      "automerge": false,
      "prBodyNotes": [
        "**SLE constraint**: Before merging, verify that SLE repos ship this Go version. Go is installed via `zypper install go${GO_VERSION}`, so only SLE-packaged versions are valid."
      ]
    },
    {
      "description": "Delve updates — require manual review for Go compat",
      "matchDepNames": [
        "go-delve/delve"
      ],
      "automerge": false,
      "prBodyNotes": [
        "**Go compatibility**: Check Delve's release notes for supported Go versions. The SLE-packaged Go version must be within Delve's supported range."
      ]
    },
    {
      "description": "k3d CLI updates",
      "matchDepNames": [
        "k3d-io/k3d"
      ],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track Go version ARG in all Dockerfiles (signal only — SLE availability must be verified manually)",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/"
      ],
      "matchStrings": [
        "ARG GO_VERSION=(?<currentValue>\\d+\\.\\d+)\\n"
      ],
      "depNameTemplate": "golang-sle",
      "packageNameTemplate": "golang",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Track Delve version ARG in Dockerfile",
      "managerFilePatterns": [
        "/^package/Dockerfile$/"
      ],
      "matchStrings": [
        "ARG DLV_VERSION=(?<currentValue>\\d+\\.\\d+\\.\\d+)\\n"
      ],
      "depNameTemplate": "go-delve/delve",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track k3d version in e2e workflow",
      "managerFilePatterns": [
        "/^\\.github/workflows/e2e\\.yml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=k3d-io/k3d\\n.*TAG=v(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "k3d-io/k3d",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ]
}
